{
	"info": {
		"_postman_id": "portfolio-api-final",
		"name": "Portfolio API - ALL IN ONE",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin2@gmail.com\",\n    \"password\": \"123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "http://localhost:3000/api/auth/login",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "3000",
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "V1 - Portfolio Core",
			"item": [
				{
					"name": "Projects",
					"item": [
						{
							"name": "Get All Projects",
							"request": {
								"method": "GET",
								"header": [],
								"url": "http://localhost:3000/api/projects"
							}
						},
						{
							"name": "Create Project (Form Data)",
							"request": {
								"method": "POST",
								"header": [
									{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
								],
								"body": {
									"mode": "formdata",
									"formdata": [
										{ "key": "title", "value": "New Web Project", "type": "text" },
										{ "key": "description", "value": "A great project", "type": "text" },
										{ "key": "image", "type": "file", "src": [] }
									]
								},
								"url": "http://localhost:3000/api/projects"
							}
						}
					]
				},
				{
					"name": "Skills",
					"item": [
						{
							"name": "Get All Skills",
							"request": {
								"method": "GET",
								"header": [],
								"url": "http://localhost:3000/api/skills"
							}
						}
					]
				},
				{
					"name": "Contacts",
					"item": [
						{
							"name": "Send Inquiry",
							"request": {
								"method": "POST",
								"body": {
									"mode": "raw",
									"raw": "{\"first_name\": \"Test\", \"last_name\": \"User\", \"email\": \"test@test.com\", \"notes\": \"Hello!\"}",
									"options": { "raw": { "language": "json" } }
								},
								"url": "http://localhost:3000/api/customers"
							}
						}
					]
				}
			]
		},
		{
			"name": "V2 - Advanced Features",
			"item": [
				{
					"name": "Products",
					"item": [
						{
							"name": "Get All Products",
							"request": {
								"method": "GET",
								"header": [],
								"url": "http://localhost:3000/api/v2/products"
							}
						},
						{
							"name": "Create Product",
							"request": {
								"method": "POST",
								"header": [
									{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
								],
								"body": {
									"mode": "formdata",
									"formdata": [
										{ "key": "name", "value": "Gaming Mouse", "type": "text" },
										{ "key": "price", "value": "25", "type": "text" },
										{ "key": "description", "value": "Fast mouse", "type": "text" }
									]
								},
								"url": "http://localhost:3000/api/v2/products"
							}
						}
					]
				},
				{
					"name": "Orders",
					"item": [
						{
							"name": "Get All Orders",
							"request": {
								"method": "GET",
								"header": [
									{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
								],
								"url": "http://localhost:3000/api/v2/orders"
							}
						}
					]
				},
				{
					"name": "Audit Logs",
					"item": [
						{
							"name": "Get Logs",
							"request": {
								"method": "GET",
								"header": [
									{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
								],
								"url": "http://localhost:3000/api/v2/auditlogs"
							}
						}
					]
				}
			]
		}
	],
	"variable": [
		{
			"key": "jwt_token",
			"value": ""
		}
	]
}
